{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "packageManager": "npm",
  "reporters": [
    "html",
    "clear-text",
    "progress"
  ],
  "ignorePatterns": ["build", "dist", "docs", "coverage", "reports", "**/*.spec.*", "**/*.stoch.*", "**/generated_code/**", "src/build_js/**" ],
  "clearTextReporter": {
    "reportMutants": false,
    "reportTests": false,
    "reportScoreTable": true
  },
  "disableTypeChecks": false,
  "tsconfigFile": "tsconfig.stryker.json",
  "testRunner": "vitest",
  "vitest": {
    "configFile": "vitest-mutat.config.ts"
  },
  "testRunner_comment": "Take a look at https://stryker-mutator.io/docs/stryker-js/vitest-runner for information about the vitest plugin.",
  "mutate": [
    "src/**/*.ts",
    "!src/**/*.spec.ts",
    "!src/**/*.stoch.ts",
    "!src/**/*.mutat.ts",
    "!src/**/e2e/**",
    "!src/build_js/**",
    "!src/scripts/**"
  ],
  "coverageAnalysis": "perTest"
}