{
  "scopeName": "markdown.fsl.codeblock",
  "injectionSelector": "L:text.html.markdown",
  "patterns": [
    { "include": "#fsl-code-block" }
  ],
  "repository": {
    "fsl-code-block": {
      "begin": "(^|\\G)(\\s*)(`{3,}|~{3,})\\s*([fF][sS][lL]|[jJ][sS][sS][mM])\\b.*$",
      "beginCaptures": {
        "3": { "name": "punctuation.definition.markdown" },
        "4": { "name": "fenced_code.block.language.markdown" }
      },
      "end": "(^|\\G)(\\2|\\s{0,3})(\\3)\\s*$",
      "endCaptures": {
        "3": { "name": "punctuation.definition.markdown" }
      },
      "name": "markdown.fsl.codeblock",
      "patterns": [
        {
          "begin": "(^(?!\\s*(`{3,}|~{3,})).*$)",
          "while": "^(?!\\s*(`{3,}|~{3,})).*$",
          "contentName": "meta.embedded.block.fsl",
          "patterns": [
            { "include": "source.fsl" }
          ]
        }
      ]
    }
  }
}
