{
  "name": "vscode-fsl",
  "displayName": "FSL Markdown Preview",
  "version": "0.3.1",
  "description": "Live FSL / jssm state machines in VS Code's Markdown preview",
  "publisher": "StoneCypher",
  "keywords": [
    "fsl",
    "jssm",
    "state machine",
    "markdown",
    "preview",
    "diagram"
  ],
  "categories": [
    "Visualization",
    "Other"
  ],
  "homepage": "https://github.com/StoneCypher/vscode-fsl#readme",
  "bugs": {
    "url": "https://github.com/StoneCypher/vscode-fsl/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/StoneCypher/vscode-fsl"
  },
  "license": "MIT",
  "author": "John Haugeland <stonecypher@gmail.com>",
  "engines": {
    "vscode": "^1.90.0"
  },
  "main": "./dist/extension.js",
  "types": "./dist/extension.d.ts",
  "exports": {
    ".": {
      "types": "./dist/extension.d.ts",
      "require": "./dist/extension.js"
    }
  },
  "activationEvents": [
    "onLanguage:markdown"
  ],
  "contributes": {
    "languages": [
      {
        "id": "fsl",
        "aliases": ["FSL", "jssm"],
        "extensions": [".fsl"],
        "configuration": "./language-configuration.json"
      }
    ],
    "markdown.markdownItPlugins": true,
    "markdown.previewScripts": [
      "./dist/preview.js"
    ],
    "grammars": [
      {
        "language": "fsl",
        "scopeName": "source.fsl",
        "path": "./syntaxes/fsl.tmLanguage.json"
      },
      {
        "scopeName": "markdown.fsl.codeblock",
        "path": "./syntaxes/fsl.markdown.injection.json",
        "injectTo": ["text.html.markdown"],
        "embeddedLanguages": {
          "meta.embedded.block.fsl": "source.fsl"
        }
      }
    ]
  },
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "postinstall": "node src/build_js/postinstall.js",
    "clean": "node src/build_js/clean.js",
    "update_madlibs": "node src/build_js/update_madlibs.js && cp README.md docs",
    "typescript": "tsc -p tsconfig.src.json",
    "typescript_tests": "tsc -p tsconfig.tests.json",
    "bundle": "node src/scripts/build.mjs",
    "terser": "node src/build_js/minify_bundles.js && cp dist/preview.js dist/preview.js.map docs",
    "verify_dist_entrypoints": "node src/build_js/verify_dist_entrypoints.js",
    "copy_grammars": "node src/build_js/copy_grammars.js",
    "dts": "cp build/ts/*.d.ts build/ts/*.d.ts.map dist/",
    "viz_png": "node src/build_js/render_visualizations.js && cp build/esbuild/visualizations/bundle_*.png . && cp build/esbuild/visualizations/bundle_*.png docs/ && cp build/esbuild/visualizations/bundle_*.png docs/docs/",
    "site": "cp src/html/* docs && cp src/html/.nojekyll docs && cp README.md docs/ && cp src/html/*.png docs/docs",
    "docs": "typedoc src/extension.ts src/preview/preview.ts --options typedoc-options.cjs --out docs/docs",
    "test": "npm run build",
    "stryker": "npx stryker run",
    "just_test": "vitest run --coverage && vitest run --config vitest-stoch.config.ts --coverage && vitest run --config vitest-mutat.config.ts --coverage",
    "just_test_save": "node src/build_js/run_tests_save.js",
    "eslint": "eslint",
    "attw": "attw --pack .",
    "cloc": "node src/build_js/run_cloc.js && node ./src/build_js/cloc_report.cjs",
    "changelog": "rm -f CHANGELOG.md && rm -f CHANGELOG.long.md && rm -f ./src/doc_md/CHANGELOG.md && rm -f ./src/doc_md/CHANGELOG.long.md && better_git_changelog -b && node src/build_js/sanitize_changelog.js && cp CHANGELOG.* ./src/doc_md/",
    "build": "node src/build_js/run_build.js",
    "package": "vsce package",
    "ci": "echo starting && node -e \"console.log(new Date().toLocaleString())\" && npm run build && echo finishing && node -e \"console.log(new Date().toLocaleString())\""
  },
  "dependencies": {
    "@viz-js/viz": "^3",
    "jssm": "^5.163.2",
    "lit": "^3",
    "viz.js": "^2.1.2"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/css": "^1.0.0",
    "@eslint/markdown": "^8.0.0",
    "@faker-js/faker": "^10.4.0",
    "@playwright/test": "^1.58.2",
    "@stryker-mutator/core": "^9.6.0",
    "@stryker-mutator/vitest-runner": "^9.6.0",
    "@types/markdown-it": "^14",
    "@types/node": "^25.5.0",
    "@types/vscode": "1.90.0",
    "@vitest/coverage-v8": "^4.1.2",
    "@vscode/vsce": "^3",
    "better_git_changelog": "^1.6.16",
    "cloc": "^2.6.0-cloc",
    "commitlint": "^20.5.0",
    "esbuild": "^0.24",
    "esbuild-visualizer": "^0.7.0",
    "eslint": "^9.39.4",
    "fast-check": "^4.6.0",
    "globals": "^17.4.0",
    "jiti": "^2.6.1",
    "jsdom": "^25",
    "markdown-it": "^14",
    "playwright": "^1.58.2",
    "rimraf": "^6.1.3",
    "servehere": "^1.10.1",
    "terser": "^5.46.1",
    "typedoc": "^0.28.18",
    "typedoc-plugin-coverage": "^4.0.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "typescript-language-server": "^5.1.3",
    "vitest": "^4.1.2",
    "zod": "^4.3.6"
  }
}
